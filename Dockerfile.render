FROM coollabsio/openclaw:latest
# Fix: remove browser sidecar proxy (not available on Render)
RUN sed -i 's|proxy_pass http://browser:3000/;|return 404;|g' /app/scripts/entrypoint.sh
# Fix: inject trusted proxies + dangerouslyDisableDeviceAuth in configure.js
RUN sed -i '/config\.gateway\.controlUi\.enabled/a\
  if (!config.gateway.trustedProxies) config.gateway.trustedProxies = ["127.0.0.1", "10.0.0.0/8"];\
  if (config.gateway.allowRealIpFallback === undefined) config.gateway.allowRealIpFallback = true;\
  config.gateway.controlUi.dangerouslyDisableDeviceAuth = true;' /app/scripts/configure.js
# Fix: runtime patch — runs AFTER configure.js to patch existing config on disk
COPY <<'EOF' /app/scripts/render-patch-config.js
const fs = require("fs");
const f = "/data/.openclaw/openclaw.json";
try {
  const c = JSON.parse(fs.readFileSync(f, "utf8"));
  const g = c.gateway = c.gateway || {};
  const ui = g.controlUi = g.controlUi || {};
  ui.dangerouslyDisableDeviceAuth = true;
  g.trustedProxies = g.trustedProxies || ["127.0.0.1", "10.0.0.0/8"];
  g.allowRealIpFallback = true;
  // Keep auth mode as token (not trusted-proxy)
  g.auth = g.auth || {};
  if (g.auth.mode === "trusted-proxy") g.auth.mode = "token";
  delete g.auth.trustedProxy;
  fs.writeFileSync(f, JSON.stringify(c, null, 2));
  console.log("[render-patch] config patched: dangerouslyDisableDeviceAuth=true");
} catch (e) {
  console.log("[render-patch] skip:", e.message);
}
EOF
# Fix: suppress incomplete-turn false positives for non-Anthropic models via OpenRouter
# Non-Anthropic models may return stopReason=stop with empty content when the agent
# payload (system prompt + tools) is too complex. Return null to suppress the error
# and let the empty-response retry handle it gracefully.
RUN find /opt/openclaw/app/dist/ -name '*.js' -exec grep -l 'resolveIncompleteTurnPayloadText' {} \; | \
    xargs -I{} sed -i 's/function resolveIncompleteTurnPayloadText(params) {/function resolveIncompleteTurnPayloadText(params) { if(params.attempt?.lastAssistant?.stopReason==="stop")return null;/' {}
# Fix: set default model to DeepSeek V3.2 via OpenRouter
RUN sed -i '/ui.dangerouslyDisableDeviceAuth/a\
  const a = c.agents = c.agents || {};\
  const d = a.defaults = a.defaults || {};\
  const m = d.model = d.model || {};\
  if (!m.primary || m.primary.includes("claude-opus-4-5")) m.primary = "openrouter/qwen/qwen3-30b-a3b";' /app/scripts/render-patch-config.js
# Inject patch AFTER configure.js so the config file exists
RUN sed -i '/^node \/app\/scripts\/configure\.js$/a node /app/scripts/render-patch-config.js' /app/scripts/entrypoint.sh
